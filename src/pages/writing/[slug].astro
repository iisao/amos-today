---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPosts, renderPageBody, formatDate } from "../../lib/notion";
import SroiCalculator from "../../components/SroiCalculator.astro";

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const bodyHtml = await renderPageBody(post.id);

// 文末條件插入互動元件
const hasSroiCalculator = post.slug === "how-to-count-impact";
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  type="article"
  publishedDate={post.publishedDate}
  tags={post.tags}
>
  <article class="mx-auto max-w-3xl px-6 pt-24 pb-24">
    <header class="mb-10">
      <p class="text-xs text-neutral-500 mb-3">{formatDate(post.publishedDate)}</p>
      <h1 class="text-3xl sm:text-4xl font-medium leading-tight tracking-tight">
        {post.title}
      </h1>
      {post.tags.length > 0 && (
        <div class="mt-4 flex gap-2 flex-wrap">
          {post.tags.map((tag) => (
            <span class="text-xs text-neutral-500">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-body" set:html={bodyHtml} />

    {hasSroiCalculator && <SroiCalculator />}

    <footer class="mt-16 pt-8 border-t border-neutral-200">
      <a href="/writing" class="text-sm">← 回所有文章</a>
    </footer>
  </article>
</BaseLayout>

<style is:global>
  .post-body { font-size: 1rem; line-height: 1.75; color: #171717; }
  .post-body > * + * { margin-top: 1.25em; }
  .post-body h2 { font-size: 1.4rem; font-weight: 500; margin-top: 2.2em; letter-spacing: -0.01em; }
  .post-body h3 { font-size: 1.15rem; font-weight: 500; margin-top: 1.8em; }
  .post-body p { color: #262626; }
  .post-body a { text-decoration: underline; text-decoration-color: #d4d4d4; text-underline-offset: 4px; }
  .post-body a:hover { text-decoration-color: #171717; }
  .post-body ul, .post-body ol { padding-left: 1.5em; }
  .post-body ul { list-style: disc; }
  .post-body ol { list-style: decimal; }
  .post-body li + li { margin-top: 0.4em; }
  .post-body blockquote { border-left: 3px solid var(--color-accent); padding-left: 1em; color: #525252; font-style: italic; }
  .post-body code { background: #f5f5f5; padding: 0.15em 0.35em; border-radius: 3px; font-size: 0.9em; }
  .post-body pre { background: #fafafa; padding: 1em; border-radius: 6px; overflow-x: auto; font-size: 0.875em; }
  .post-body pre code { background: transparent; padding: 0; }
  .post-body img {
    display: block;
    margin: 3.2em auto;
    max-width: 72%;
    height: auto;
    border-radius: 2px;
    border: 1px solid #ececec;
  }
  .post-body figure { margin: 3.2em auto; max-width: 72%; }
  .post-body figure img { margin: 0 auto; max-width: 100%; }
  .post-body figcaption {
    margin-top: 0.7em;
    text-align: center;
    color: #737373;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  @media (max-width: 640px) {
    .post-body img { max-width: 92%; margin: 2.2em auto; }
    .post-body figure { max-width: 92%; margin: 2.2em auto; }
    /* 手機：首圖高度設上限，避免大圖把標題與首段推出畫面 */
    .post-body figure img,
    .post-body img { max-height: 60vh; width: auto; }
  }
  .post-body hr { border: 0; border-top: 1px solid #e5e5e5; margin: 2.5em 0; }
  /* 圖片出處／附註行：灰階小字＋上分隔線，與圖說一致（由 renderer 掛 class） */
  .post-body p.img-credit {
    margin-top: 2.5em;
    padding-top: 1.1em;
    border-top: 1px solid #ececec;
    font-size: 0.85rem;
    color: #737373;
  }
  .post-body p.img-credit a { text-decoration-color: #c4c4c4; }
  .post-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.6em 0;
    font-size: 0.94em;
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    overflow: hidden;
  }
  .post-body th,
  .post-body td {
    padding: 0.72em 0.9em;
    border-bottom: 1px solid #e5e5e5;
    text-align: left;
    vertical-align: top;
    line-height: 1.7;
  }
  .post-body th {
    background: #fafafa;
    font-weight: 500;
    color: #262626;
    font-size: 0.92em;
    border-bottom-color: #d4d4d4;
    letter-spacing: 0.02em;
  }
  .post-body tbody tr:last-child td { border-bottom: none; }
  .post-body td strong { color: #171717; font-weight: 600; }
  @media (max-width: 640px) {
    .post-body table {
      font-size: 0.88em;
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    .post-body th,
    .post-body td { padding: 0.58em 0.7em; }
  }
</style>
