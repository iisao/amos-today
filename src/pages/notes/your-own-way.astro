    color: #737373;
    font-size: 0.9rem;
    margin-top: 0.9rem;
  }
  .note .hero { margin: 2em 0 0.5em; }
  .note .hero img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
  }
  .note .inline { margin: 2.4em 0; }
  .note .inline img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid #e5e5e5;
  }
  .note .inline figcaption {
    margin-top: 0.7em;
    text-align: center;
    color: #737373;
    font-size: 0.85rem;
  }
  .note p { margin-top: 1.3em; text-align: justify; }
  .note p.short {
    text-align: center;
    color: #404040;
    font-size: 1.1rem;
    margin: 2em 0;
  }
  .note p.echo {
    text-align: center;
    color: #262626;
    font-size: 1.25rem;
    letter-spacing: 0.1em;
    margin: 2.4em 0 1.6em;
  }
  .note .sign {
    text-align: center;
    color: #737373;
    font-size: 0.95rem;
    letter-spacing: 0.08em;
    margin-top: 2.4em;
  }
</style>
