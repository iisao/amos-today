---
import BaseLayout from "../../layouts/BaseLayout.astro";

const notes = [
  {
    slug: "always-with-you",
    title: "爸爸一直會陪你",
    meta: "致盼盼 ｜ 2026 夏",
    blurb:
      "女兒臨時打來求救填志願，剩一個多小時。那半小時讓我明白，重心從來不是去外面找來的，是有人需要你、而你剛好在。",
  },
  {
    slug: "cai-tuo",
    title: "蔡拖小傳",
    meta: "家族 ｜ 羅東木業",
    blurb:
      "雲林四湖箔子寮漁村出身，在異鄉羅東白手起家的木業人，我的阿祖。資料很少的那個人，其實一生很重。",
    cover: "/notes/cai/feast.jpg",
  },
  {
    slug: "grandma",
    title: "記得外婆",
    meta: "家族 ｜ 2026 清明",
    blurb:
      "與外婆黃藍阿惜道別。我已經寫完了，但為什麼還是盯著捕蚊燈一直在哭。",
    cover: "/notes/grandma/young.jpg",
  },
];
---

<BaseLayout title="記事" description="寫給家人的、與工作無關的文字。">
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-16">
    <h1 class="text-3xl sm:text-4xl font-medium leading-tight tracking-tight">
      記事
    </h1>
    <p class="mt-6 text-neutral-500">
      寫給家人的、與工作無關的文字。
    </p>

    <ul class="mt-12 space-y-10">
      {notes.map((n) => (
        <li class="border-b border-neutral-100 pb-10">
          <a href={`/notes/${n.slug}`} class="flex gap-5 no-underline group">
            {n.cover && (
              <img
                src={n.cover}
                alt={n.title}
                class="w-28 h-28 sm:w-32 sm:h-32 object-cover rounded-lg border border-neutral-200 shrink-0"
              />
            )}
            <div>
              <h2 class="text-lg font-medium group-hover:opacity-70">{n.title}</h2>
              <span class="text-xs text-neutral-400">{n.meta}</span>
              <p class="mt-2 text-sm text-neutral-500 leading-relaxed">{n.blurb}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
