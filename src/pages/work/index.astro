---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="作品" description="樂創媒體與 Amos 經手的專案、提案、產品線。">
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-16">
    <h1 class="text-3xl sm:text-4xl font-medium leading-tight tracking-tight">
      作品
    </h1>
    <p class="mt-6 text-neutral-500">
      樂創媒體（LAFUN）與我經手的專案、提案、產品線。
    </p>

    <div class="mt-12">
      <p class="text-neutral-500 italic">（作品集即將上線）</p>
    </div>
  </section>
</BaseLayout>
