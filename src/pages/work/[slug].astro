---
import fs from "node:fs";
import path from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getProjects, renderPageBody } from "../../lib/notion";

export async function getStaticPaths() {
  const projects = await getProjects();
  return projects.map((proj) => ({
    params: { slug: proj.slug },
    props: { project: proj },
  }));
}

const { project } = Astro.props;
const bodyHtml = await renderPageBody(project.id);

// 社群分享 OG 圖：有專屬卡 /work/<slug>/og.jpg（1200×630）就用，沒有則 BaseLayout 退回站台預設 /og.png。
const ogCard = `/work/${project.slug}/og.jpg`;
const ogImage = fs.existsSync(path.join(process.cwd(), "public", ogCard)) ? ogCard : undefined;
---

<BaseLayout title={project.title} description={project.summary} image={ogImage} type="article">
  <article class="mx-auto max-w-3xl px-6 pt-24 pb-24">
    <header class="mb-10">
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 text-xs text-neutral-500 mb-3">
        {project.year && <span>{project.year}</span>}
        {project.type && <span>{project.type}</span>}
        {project.code && <span class="font-mono">{project.code}</span>}
      </div>
      <h1 class="text-3xl sm:text-4xl font-medium leading-tight tracking-tight">
        {project.title}
      </h1>
      {project.summary && (
        <p class="mt-5 text-base text-neutral-600">{project.summary}</p>
      )}

      <dl class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-y-3 gap-x-8 text-sm border-t border-neutral-200 pt-6">
        {project.client && (
          <div>
            <dt class="text-neutral-500">客戶 / 單位</dt>
            <dd class="mt-1">{project.client}</dd>
          </div>
        )}
        {project.role && (
          <div>
            <dt class="text-neutral-500">角色</dt>
            <dd class="mt-1">{project.role}</dd>
          </div>
        )}
      </dl>
    </header>

    <div class="post-body" set:html={bodyHtml} />

    <footer class="mt-16 pt-8 border-t border-neutral-200">
      <a href="/work" class="text-sm">← 回所有作品</a>
    </footer>
  </article>
</BaseLayout>

<style is:global>
  .post-body { font-size: 1rem; line-height: 1.75; color: #171717; }
  .post-body > * + * { margin-top: 1.25em; }
  .post-body h2 { font-size: 1.4rem; font-weight: 500; margin-top: 2.2em; letter-spacing: -0.01em; }
  .post-body h3 { font-size: 1.15rem; font-weight: 500; margin-top: 1.8em; }
  .post-body p { color: #262626; }
  .post-body a { text-decoration: underline; text-decoration-color: #d4d4d4; text-underline-offset: 4px; }
  .post-body a:hover { text-decoration-color: #171717; }
  .post-body ul, .post-body ol { padding-left: 1.5em; }
  .post-body ul { list-style: disc; }
  .post-body ol { list-style: decimal; }
  .post-body li + li { margin-top: 0.4em; }
  .post-body blockquote { border-left: 3px solid var(--color-accent); padding-left: 1em; color: #525252; font-style: italic; }
  .post-body code { background: #f5f5f5; padding: 0.15em 0.35em; border-radius: 3px; font-size: 0.9em; }
  .post-body pre { background: #fafafa; padding: 1em; border-radius: 6px; overflow-x: auto; font-size: 0.875em; }
  .post-body pre code { background: transparent; padding: 0; }
  .post-body img { border-radius: 6px; max-width: 100%; height: auto; }
  .post-body figure { margin: 2.4em auto; }
  .post-body figure img { display: block; margin: 0 auto; }
  .post-body figcaption {
    margin-top: 0.7em;
    text-align: center;
    color: #737373;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .post-body hr { border: 0; border-top: 1px solid #e5e5e5; margin: 2.5em 0; }
</style>
