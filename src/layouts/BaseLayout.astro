---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedDate?: string | null;
  tags?: string[];
}

const {
  title,
  description,
  image,
  type = "website",
  publishedDate,
  tags = [],
} = Astro.props;

const siteName = "Amos｜樂創媒體";
const homeTitle = "Amos 蔡尚勲（Amos Tsai）｜樂創媒體 LAFUN";
const fullTitle = title ? `${title}｜${siteName}` : homeTitle;
const desc =
  description ??
  "Amos（蔡尚勲 / Amos Tsai）的個人作品集與觀點站，樂創媒體 LAFUN 創辦人。我用結構說故事，用故事推進。";

// 名字與品牌變體（供搜尋與 AI 辨識）
const keywords =
  "蔡尚勲, 蔡尚勳, Amos, Amos Tsai, 樂創媒體, Lafun Media, 樂創未來式, 樂創進行式";

const site = Astro.site ?? new URL("https://amos.today");
const canonicalURL = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image ?? "/og.png", site).href;

// ── 結構化資料 JSON-LD ───────────────────────────────────
const person = {
  "@type": "Person",
  "@id": `${site.origin}/#amos`,
  name: "蔡尚勲",
  alternateName: ["蔡尚勳", "Amos", "Amos Tsai"],
  url: site.origin,
  jobTitle: "創辦人、創意總監",
  worksFor: { "@id": `${site.origin}/#lafun` },
  sameAs: ["https://www.lafun.media"],
};
const organization = {
  "@type": "Organization",
  "@id": `${site.origin}/#lafun`,
  name: "樂創媒體",
  alternateName: ["Lafun Media", "LAFUN", "樂創未來式", "樂創進行式"],
  url: "https://www.lafun.media",
  founder: { "@id": `${site.origin}/#amos` },
};
const website = {
  "@type": "WebSite",
  "@id": `${site.origin}/#website`,
  url: site.origin,
  name: siteName,
  inLanguage: "zh-Hant",
  publisher: { "@id": `${site.origin}/#amos` },
};

const graph: Record<string, unknown>[] = [person, organization, website];
if (type === "article") {
  graph.push({
    "@type": "BlogPosting",
    headline: title,
    description: desc,
    inLanguage: "zh-Hant",
    url: canonicalURL,
    mainEntityOfPage: canonicalURL,
    image: ogImage,
    author: { "@id": `${site.origin}/#amos` },
    publisher: { "@id": `${site.origin}/#lafun` },
    ...(publishedDate ? { datePublished: publishedDate, dateModified: publishedDate } : {}),
    ...(tags.length ? { keywords: tags.join(", ") } : {}),
  });
}
const jsonLd = { "@context": "https://schema.org", "@graph": graph };
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="蔡尚勲 Amos Tsai" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonicalURL} />

    <meta name="theme-color" content="#1a4d3a" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="zh_TW" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Noto+Sans+TC:wght@400;500&family=Noto+Serif+TC:wght@500;700&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-neutral-200">
      <div class="mx-auto max-w-3xl px-6 py-6 flex items-center justify-between text-sm">
        <a href="/" class="font-medium no-underline hover:opacity-70">amos.today</a>
        <nav class="flex gap-6">
          <a href="/work" class="no-underline hover:opacity-70">Work</a>
          <a href="/writing" class="no-underline hover:opacity-70">Writing</a>
          <a href="/notes" class="no-underline hover:opacity-70">Notes</a>
          <a href="/about" class="no-underline hover:opacity-70">About</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-neutral-200 mt-24">
      <div class="mx-auto max-w-3xl px-6 py-8 text-sm text-neutral-500 flex flex-col sm:flex-row gap-2 justify-between">
        <span>© {new Date().getFullYear()} Amos · 樂創媒體</span>
        <span>
          <a href="mailto:amos@za.media" class="no-underline hover:text-neutral-900">amos@za.media</a>
        </span>
      </div>
    </footer>
  </body>
</html>
